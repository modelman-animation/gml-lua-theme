{
    "name": "GameMaker Lua Theme",
    "colors": {
        "editor.background": "#222222"
    },
    "tokenColors": [
        {
            "scope": "comment",
            "settings": {
                "foreground": "#5B995B"
            }
        },
        {
            "scope": ["keyword", "keyword.local"],
            "settings": {
                "foreground": "#FFB871",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["constant.numeric", "number"],
            "settings": {
                "foreground": "#FF8080"
            }
        },
        {
            "scope": "string",
            "settings": {
                "foreground": "#FFFF00"
            }
        },
        {
            "scope": ["entity.name.function", "support.function"],
            "settings": {
                "foreground": "#FFB871"
            }
        },
        {
            "scope": "variable",
            "settings": {
                "foreground": "#B2B1FF"
            }
        },
        {
            "scope": "keyword.operator.lua",
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": "variable.language",
            "settings": {
                "foreground": "#FF8080"
            }
        },
        {
            "scope": "constant.language",
            "settings": {
                "foreground": "#FF8080"
            }
        },
        {
            "scope": "entity.other.attribute.lua",
            "settings": {
                "foreground": "#FFF899"
            }
        },
        {
            "scope": "variable.other.lua",
            "settings": {
                "foreground": "#B2B1FF"
            }
        },
        {
            "scope": "variable.global.lua",
            "settings": {
                "foreground": "#FF7EFF"
            }
        }
    ]
}